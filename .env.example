# Copy to .env and fill in values. Do not commit .env.

# Gmail: use an App Password (not your normal password).
SENDER_EMAIL=your.address@gmail.com
SENDER_PASSWORD=your_app_password_here
RECEIVER_EMAIL=recipient@example.com

# Optional SMTP overrides (defaults: Gmail + STARTTLS on 587)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Listing source — use this (main "Latest jobs" feed on UNjobs).
# Do not use https://unjobs.org/latest (invalid; returns a site error).
UNJOBS_URL=https://unjobs.org/new

# Pages to crawl (1 = first page only)
MAX_PAGES=3

# Where to store URLs already emailed
STATE_PATH=data/seen_jobs.json

# Cap detail-page fetches per run (closing dates + guardrail text + keyword refinement)
MAX_DETAIL_FETCHES=50

# Seconds between HTTP requests (be polite to the origin)
REQUEST_DELAY_SECONDS=0.5
