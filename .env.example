# Copy to .env for local runs. Do not commit .env or real secrets.

# Serper (https://serper.dev) — optional; not used by the digest script yet
SERPER_API_KEY=your_serper_api_key_here

# Google AI Studio / Gemini — optional; not used by the digest script yet
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail SMTP (App Password, not your normal login password)
GMAIL_USER=your.address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Digest recipient
NOTIFY_TO_EMAIL=recipient@example.com

# Legacy aliases (optional; script also accepts these)
# SENDER_EMAIL=
# SENDER_PASSWORD=
# RECEIVER_EMAIL=

# Optional SMTP overrides (defaults: Gmail + STARTTLS on 587)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Listing source — use https://unjobs.org/new (not /latest)
UNJOBS_URL=https://unjobs.org/new

# Pages to crawl (default 6 in code; GitHub Actions workflow sets 6)
MAX_PAGES=6

# Where to store URLs already emailed
STATE_PATH=data/seen_jobs.json

# Cap detail-page fetches per run
MAX_DETAIL_FETCHES=50

# Seconds between HTTP requests
REQUEST_DELAY_SECONDS=0.5
